# Base de datos PostgreSQL (Neon)
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Secreto para JWT (usar un string largo y aleatorio)
JWT_SECRET="tu_secreto_super_largo_y_aleatorio_aqui"

# Secreto para comunicación entre APIs (backend IA)
API_SECRET="tu_secreto_api_aqui"

# API Key de Groq para IA
GROQ_API_KEY="gsk_your_groq_api_key_here"

# URL del backend de IA (Render)
BACKEND_IA_URL="https://tu-backend-ia.onrender.com"

# URL de la aplicación frontend (Vercel)
NEXT_PUBLIC_APP_URL="https://legajos-dajudeco.vercel.app"

# URL del logo (opcional)
NEXT_PUBLIC_LOGO_URL="/logo-mpa.png"

# Email para notificaciones
EMAIL_RESPUESTA="email@ejemplo.com"

# Configuración de Redis para rate limiting (opcional)
REDIS_URL="redis://username:password@host:6379"

# Umbral de alertas (días)
DIAS_ALERTA_MEDIA=2
DIAS_ALERTA_ALTA=3
DIAS_ALERTA_CRITICA=7
