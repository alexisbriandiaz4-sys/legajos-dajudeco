generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  usuario   String   @unique
  password  String
  rol       String   @default("investigador")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  legajos   Legajo[]
  fiscales      Fiscal[]
}

model Legajo {
  id            String   @id @default(cuid())
  numero        String   @unique
  caratula      String
  cuij          String?
  delito        String
  fechaHecho    DateTime
  estado        String   @default("Activo")
  observaciones String?
  fiscal         String?
  emailRespuesta String?
  visto         Boolean  @default(false)
  origenTipo    String?
  origenId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
  victimas      Victima[]
  dispositivos  Dispositivo[]
  oficios       Oficio[]
  archivos    ArchivoLegajo[]
}

model Victima {
  id        String  @id @default(cuid())
  nombre    String
  dni       String?
  telefono  String?
  email     String?
  legajoId  String
  legajo    Legajo  @relation(fields: [legajoId], references: [id], onDelete: Cascade)
}

model Dispositivo {
  id       String  @id @default(cuid())
  tipo     String
  marca    String?
  modelo   String?
  imei     String?
  color    String?
  numeroLinea String?
  legajoId String
  legajo   Legajo  @relation(fields: [legajoId], references: [id], onDelete: Cascade)
}

model Oficio {
  id             String    @id @default(cuid())
  numero         String?
  operadora      String
  tipo           String
  fechaEnvio     DateTime?
  fechaRespuesta DateTime?
  estado         String    @default("Pendiente")
  urgencia       String    @default("48 horas")
  observaciones  String?
  columnas      String?
  tipoConsulta  String?
  numeroLinea   String?
  imeiSeleccionado  String?
  createdAt      DateTime  @default(now())
  legajoId       String
  legajo         Legajo    @relation(fields: [legajoId], references: [id], onDelete: Cascade)
  respuestas     Respuesta[]
}

model Respuesta {
  id        String   @id @default(cuid())
  oficioId  String
  oficio    Oficio   @relation(fields: [oficioId], references: [id], onDelete: Cascade)
  datos     String
  createdAt DateTime @default(now())
}

model Fiscal {
  id              String   @id @default(cuid())
  nombre          String
  cargo           String?
  fiscalia        String?
  secretario      String?
  dniSecretario   String?
  dni             String?
  email           String?
  emailSecretario String?
  direccion       String?
  telefono        String?
  telefonoMovil   String?
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  usuarioId       String
  usuario         Usuario  @relation(fields: [usuarioId], references: [id])
}
model Configuracion {
  id                    String   @id @default("global")
  emailRespuesta        String   @default("")
  diasAlertaMedia       Int      @default(2)
  diasAlertaAlta        Int      @default(3)
  diasAlertaCritica     Int      @default(7)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
model RegistroTelefonia {
  id             String    @id @default(cuid())
  anio           Int?
  nroLegajo      String?
  nroInterno     Int?
  cuij           String?
  fechaHecho     DateTime?
  fechaIngreso   DateTime?
  lugarHecho     String?
  barrio         String?
  victima        String?
  causa          String?
  aparato        String?
  empresa        String?
  abonado        String?
  imei           String?
  color          String?
  correo         String?
  clave          String?
  fiscal         String?
  depOrigen      String?
  nroCom         String?
  rpiComisaria   String?
  rpiCompleja    String?
  observaciones  String?
  estadoLegajo   String?
  elevaciones    String?
  imputados      String?
  requisa        String?
  procedimientos String?
  asignadoA   String?
  visto       Boolean  @default(false)
  createdAt      DateTime  @default(now())

  @@index([victima])
  @@index([imei])
  @@index([nroLegajo])
  @@index([anio])
  @@index([causa])
}
model RegistroEstafa {
  id                  String    @id @default(cuid())
  nroInterno          Int?
  cuij                String?
  fechaHecho          DateTime?
  fechaDenuncia       DateTime?
  dependencia         String?
  nroLegajo           String?
  recibido            DateTime?
  victima             String?
  telefonoVictima     String?
  caratula            String?
  fiscal              String?
  ardid               String?
  seudonimo           String?
  telefonoReferencia  String?
  nombreReferencia    String?
  imei                String?
  otrosTelefonos      String?
  cbu                 String?
  titulares           String?
  filaExcel           Int?
  otrosCbu            String?
  estadoLegajo        String?
  complementos        String?
  asignadoA   String?
  visto       Boolean  @default(false)
  createdAt           DateTime  @default(now())

  @@index([victima])
  @@index([nroLegajo])
  @@index([ardid])
  @@index([imei])
  @@index([cbu])
  @@index([fechaHecho])
  @@index([filaExcel])
}
model ArchivoLegajo {
  id          String   @id @default(cuid())
  legajoId    String
  legajo      Legajo   @relation(fields: [legajoId], references: [id], onDelete: Cascade)
  nombre      String
  tipo        String
  url         String
  publicId    String
  tamano      Int?
  esAnalizable Boolean @default(false)
  analisis    String?
  createdAt   DateTime @default(now())

  @@index([legajoId])
}